# ==============================================================================
# Bazi NPC Engine - Makefile
# 功能描述：通用開發指令集
# ==============================================================================

.PHONY: all build test fmt vet run clean

all: build test

# ==============================================================================
# 編譯相關
# ==============================================================================

build:
	@echo ">>> 正在編譯專案..."
	go build -v ./...

# ==============================================================================
# 測試相關
# ==============================================================================

test:
	@echo ">>> 正在執行測試..."
	go test -v ./...

test-unit:
	@echo ">>> 正在執行單元測試..."
	go test -v ./tests/unit/...

test-integration:
	@echo ">>> 正在執行整合測試..."
	go test -v ./tests/integration/...

# ==============================================================================
# 代碼品質
# ==============================================================================

fmt:
	@echo ">>> 正在格式化程式碼..."
	go fmt ./...

vet:
	@echo ">>> 正在執行靜態分析..."
	go vet ./...

lint: fmt vet
	@echo ">>> Lint 檢查完成"

# ==============================================================================
# 運作相關
# ==============================================================================

run:
	@echo ">>> 正在執行 npcgen..."
	go run ./cmd/npcgen/main.go $(filter-out $@,$(MAKECMDGOALS))

# ==============================================================================
# 清理相關
# ==============================================================================

clean:
	@echo ">>> 正在清理..."
	go clean -cache -testcache
	rm -rf vendor/

# ==============================================================================
# 其他
# ==============================================================================

help:
	@echo "可用指令："
	@echo "  make build      - 編譯專案"
	@echo "  make test       - 執行所有測試"
	@echo "  make fmt        - 格式化程式碼"
	@echo "  make vet        - 靜態分析"
	@echo "  make run        - 執行 npcgen"
	@echo "  make clean      - 清理快取"
	@echo "  make help       - 顯示-help"
