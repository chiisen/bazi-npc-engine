# ==============================================================================
# Git Ignore - Go Project
# ==============================================================================

# ==============================================================================
# 區域變數與編譯輸出
# ==============================================================================
*.exe
*.exe~
*.dll
*.so
*.dylib

# 測試二進位檔案
*.test

# 解壓縮檔案
*.out

# Go 工作目錄
vendor/

# Go 二進位檔案
bin/
dist/

# Go 模組.cache
.gox/

# Go 關閉文件
doc.go

# ==============================================================================
# IDE 與編輯器檔案
# ==============================================================================

# VS Code
.vscode/

# GoLand / IntelliJ
.idea/

# Mac
.DS_Store
.AppleDouble
.LSOverride

# 簽名檔案
*.sign

# ==============================================================================
# 測試與覆蓋率
# ==============================================================================
coverage.html
coverage.*
*.cover
*.testcache

# ==============================================================================
# 文件
# ==============================================================================
*.md
!.gitignore
!docs/README.md
!TODO.md
!PROJECT.md
!CHANGELOG.md

# ==============================================================================
# 可能敏感的檔案
# ==============================================================================
.env
.env.local
.env.*.local
*.key
*.pem
secrets.yaml

# ==============================================================================
# 專案執行檔
# ==============================================================================
npcgen
npcgen.*

